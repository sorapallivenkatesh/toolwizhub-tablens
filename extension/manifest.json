{
  "manifest_version": 3,
  "name": "TabLens — Page Companion",
  "version": "1.0.0",
  "description": "Your lens on every tab — time per site, scroll memory, sticky notes, page-change alerts, and a daily streak. Runs 100% locally, nothing uploaded.",
  "permissions": [
    "storage",
    "tabs",
    "idle",
    "alarms",
    "scripting"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TabLens",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open the TabLens dashboard"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
